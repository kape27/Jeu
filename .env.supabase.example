# Configuration Supabase pour le mode compétition
# Copiez ce fichier vers .env.supabase et remplissez avec vos vraies valeurs

# URL de votre projet Supabase (ex: https://xxxxx.supabase.co)
SUPABASE_URL=https://votre-projet.supabase.co

# Clé anonyme publique de Supabase
SUPABASE_ANON_KEY=votre_anon_key_ici

# Clé publique (même que ANON_KEY généralement)
SUPABASE_PUBLISHABLE_KEY=votre_publishable_key_ici

# Clé de service (ATTENTION: ne jamais commiter cette clé!)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# Instructions:
# 1. Allez sur https://supabase.com
# 2. Créez un nouveau projet ou utilisez un existant
# 3. Allez dans Settings > API
# 4. Copiez les clés dans ce fichier
# 5. Renommez ce fichier en .env.supabase
