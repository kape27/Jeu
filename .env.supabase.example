# Supabase runtime config (copy to .env.supabase locally)
# Never commit real secrets in .env.supabase

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_for_client_only
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_for_client_only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_server_only
